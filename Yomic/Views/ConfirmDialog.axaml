<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Yomic.Views.ConfirmDialog"
        Width="400" Height="220"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        ShowInTaskbar="False"
        CanResize="False"
        Background="Transparent"
        TransparencyLevelHint="Transparent">

    <Border Background="{DynamicResource PrimaryBackground}" CornerRadius="16" BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="1" Padding="24">
        <Grid RowDefinitions="Auto, *, Auto">
            <!-- Header -->
            <TextBlock x:Name="TitleText" Grid.Row="0" Text="Confirm" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,10"/>
            
            <!-- Message -->
            <TextBlock x:Name="MessageText" Grid.Row="1" Text="Are you sure?" FontSize="14" Foreground="{DynamicResource SecondaryText}" TextWrapping="Wrap"/>
            
            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
                <Button Content="Cancel" Click="OnCancelClick" 
                        Background="Transparent" Foreground="{DynamicResource PrimaryText}" FontWeight="SemiBold"
                        CornerRadius="8" Padding="20,10" Cursor="Hand" BorderThickness="0">
                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                        </Style>
                    </Button.Styles>
                </Button>
                <Button Content="Confirm" Click="OnConfirmClick"
                        Background="#FF5555" Foreground="White" FontWeight="SemiBold"
                        CornerRadius="8" Padding="20,10" Cursor="Hand" BorderThickness="0">
                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#DD4444"/>
                        </Style>
                    </Button.Styles>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
