<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Yomic.Views.Components.ExtensionReminderSnackbar"
             x:Name="SnackbarRoot"
             HorizontalAlignment="Center"
             VerticalAlignment="Bottom"
             Margin="20,0,20,30"
             IsVisible="False">
    
    <UserControl.Styles>
        <!-- Button Styles -->
        <Style Selector="Button.AccentBtn">
            <Setter Property="Background" Value="#FF9500"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.AccentBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#FFB040"/>
        </Style>
        
        <Style Selector="Button.SecondaryBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#89B4FA"/>
            <Setter Property="BorderBrush" Value="#89B4FA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.SecondaryBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1A89B4FA"/>
        </Style>
        
        <Style Selector="Button.GhostBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.GhostBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="Foreground" Value="#BBB"/>
        </Style>
    </UserControl.Styles>
    
    <UserControl.Transitions>
        <Transitions>
            <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut"/>
        </Transitions>
    </UserControl.Transitions>
    
    <!-- Main Container -->
    <Border Background="{DynamicResource SidebarBackground}"
            BorderBrush="{DynamicResource SeparatorBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Padding="24,20"
            BoxShadow="0 8 32 #40000000"
            MaxWidth="580"
            MinWidth="400">
        
        <Grid RowDefinitions="Auto,Auto,Auto">
            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                <TextBlock Text="&#xE8FD;" 
                           FontFamily="Segoe Fluent Icons" 
                           FontSize="24" 
                           Foreground="{DynamicResource PrimaryAccent}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Mengalami kendala pada Extension?" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource PrimaryText}"
                           VerticalAlignment="Center"/>
            </StackPanel>
            
            <!-- Body -->
            <TextBlock Grid.Row="1" 
                       Text="Cek dan download versi terbaru di repository kami. Jika masalah berlanjut, silakan kirim Feedback." 
                       FontSize="14" 
                       Foreground="{DynamicResource SecondaryText}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20"
                       LineHeight="22"/>
            
            <!-- Action Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <Button Classes="GhostBtn" Click="OnDismissClick"
                        Foreground="{DynamicResource SecondaryText}">
                    <TextBlock Text="Tutup" FontSize="13"/>
                </Button>
                <Button Classes="SecondaryBtn" Click="OnContactDevClick"
                        Foreground="{DynamicResource PrimaryAccent}"
                        BorderBrush="{DynamicResource PrimaryAccent}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="&#xE715;" FontFamily="Segoe Fluent Icons" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Send Feedback" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Classes="AccentBtn" Click="OnDownloadClick"
                        Background="{DynamicResource PrimaryAccent}"
                        Foreground="White">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="&#xE896;" FontFamily="Segoe Fluent Icons" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Download Update" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
