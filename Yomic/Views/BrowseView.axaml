<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Yomic.ViewModels"
             xmlns:helpers="clr-namespace:Yomic.Views.Helpers"
             x:Class="Yomic.Views.BrowseView"
             x:DataType="vm:BrowseViewModel"
             Background="{DynamicResource PrimaryBackground}">

    <UserControl.Styles>
        <!-- Standard Header Action Button Style -->
        <Style Selector="Button.header-action">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
        </Style>
        <Style Selector="Button.header-action:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#15FFFFFF"/>
        </Style>
        <Style Selector="Button.header-action:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        </Style>
        <Style Selector="Button.header-action:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#25FFFFFF"/>
        </Style>
        <Style Selector="Button.header-action TextBlock">
             <Setter Property="Transitions" Value="{x:Null}"/>
        </Style>
        <!-- Tab Filter Style (ListBoxItem) -->
        <Style Selector="#LanguageFilterListBox ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <BrushTransition Property="Foreground" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="#LanguageFilterListBox ListBoxItem /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="#LanguageFilterListBox ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
        </Style>
        <Style Selector="#LanguageFilterListBox ListBoxItem:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        </Style>
        <Style Selector="#LanguageFilterListBox ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PrimaryBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="#LanguageFilterListBox ListBoxItem:selected">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        </Style>
    </UserControl.Styles>

    <Panel>
        <Grid RowDefinitions="Auto, *" IsVisible="{Binding !IsOffline}">
        <StackPanel Grid.Row="0" Spacing="15" Margin="30,25,30,10" ZIndex="10">
            <!-- Header -->
            <StackPanel>
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons" FontSize="22" 
                                   Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"
                                   RenderOptions.TextRenderingMode="Antialias"/>
                        <TextBlock Text="Browse Source" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>

                    </StackPanel>
                </Grid>

            </StackPanel>

            <!-- Search Box & Filter Button -->
            <Grid ColumnDefinitions="*, Auto">
                <TextBox Grid.Column="0" Width="300" HorizontalAlignment="Left"
                          Text="{Binding SearchText}"
                          Watermark="Search sources..." 
                          Background="{DynamicResource SidebarBackground}" Foreground="{DynamicResource PrimaryText}" 
                          CornerRadius="20" Padding="12,8"
                          BorderThickness="0" VerticalContentAlignment="Center" FontSize="13">
                    <TextBox.Styles>
                        <Style Selector="TextBox:focus">
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryText}"/>
                        </Style>
                        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                            <Setter Property="Background" Value="{DynamicResource SidebarBackground}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                            <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                         <Style Selector="TextBox:pointerover">
                             <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                         </Style>
                         <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
                             <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
                         </Style>
                         <Style Selector="TextBox:focus /template/ TextBlock#PART_Watermark">
                             <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
                         </Style>
                         <Style Selector="TextBox:pointerover /template/ TextBlock#PART_Watermark">
                             <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
                         </Style>
                    </TextBox.Styles>
                    <TextBox.InnerRightContent>
                        <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource SecondaryText}" 
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                    </TextBox.InnerRightContent>
                </TextBox>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="10,0,0,0" VerticalAlignment="Center">
                    <!-- Filter Button -->
                    <Button Classes="header-action" ToolTip.Tip="Filter by Language">
                        <Button.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                <MenuItem Header="Filter By" IsEnabled="False" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource SecondaryText}"/>
                                
                                <MenuItem Header="Show All" Command="{Binding SetLanguageFilterCommand}" CommandParameter="ALL">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource AccentColor}"
                                                   IsVisible="{Binding SelectedLanguage, Converter={x:Static ObjectConverters.Equal}, ConverterParameter='ALL'}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Bahasa Indonesia" Command="{Binding SetLanguageFilterCommand}" CommandParameter="ID">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource AccentColor}"
                                                   IsVisible="{Binding SelectedLanguage, Converter={x:Static ObjectConverters.Equal}, ConverterParameter='ID'}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="English" Command="{Binding SetLanguageFilterCommand}" CommandParameter="EN">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource AccentColor}"
                                                   IsVisible="{Binding SelectedLanguage, Converter={x:Static ObjectConverters.Equal}, ConverterParameter='EN'}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </MenuFlyout>
                        </Button.Flyout>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#xE71C;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Filter" VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </StackPanel>

            <!-- Main Content (Online) -->
            <Panel Grid.Row="1">
                <ListBox ItemsSource="{Binding Sources}" 
                         Background="Transparent" 
                         BorderThickness="0"
                         Padding="30,10,30,50"
                         VerticalAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         IsVisible="{Binding HasSources}">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListBox.Styles>

                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="8"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Button x:CompileBindings="False" Background="Transparent" Padding="0" Margin="0,0,0,4"
                                    Command="{Binding DataContext.OpenSourceCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}}"
                                    CommandParameter="{Binding}" HorizontalAlignment="Stretch">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                    <Style Selector="Button:pressed /template/ ContentPresenter">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                </Button.Styles>
                                
                                <!-- List Item Background -->
                                <Border CornerRadius="8" Padding="15,10"
                                        Background="{DynamicResource SidebarBackground}" BorderThickness="0" BorderBrush="{DynamicResource SeparatorBrush}">
                                    <Border.Styles>
                                        <Style Selector="Border">
                                            <Setter Property="Transitions">
                                                <Transitions>
                                                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                                                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                                                </Transitions>
                                            </Setter>
                                        </Style>
                                        <Style Selector="Border:pointerover">
                                            <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                                            <Setter Property="RenderTransform" Value="translateX(4px)"/>
                                        </Style>
                                    </Border.Styles>

                                    <Grid ColumnDefinitions="Auto, *, Auto, Auto">
                                        <!-- Col 1: Icon -->
                                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="8" Background="{Binding IconColor}" Margin="0,0,15,0" ClipToBounds="True">
                                             <Panel>
                                                 <TextBlock Text="{Binding IconText}" Foreground="{Binding IconForeground}" FontWeight="ExtraBold" FontSize="20"
                                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                                            IsVisible="{Binding IconText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                 <Image Source="{Binding IconBitmap}" Stretch="UniformToFill" IsVisible="{Binding IconBitmap, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                 <ProgressBar IsIndeterminate="True" Height="4" VerticalAlignment="Bottom" 
                                                              Foreground="{DynamicResource PrimaryAccent}" Background="Transparent"
                                                              IsVisible="{Binding IsLoadingIcon}"/>
                                             </Panel>
                                        </Border>
                                        
                                        <!-- Col 2: Name & Version -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" Spacing="2">
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource PrimaryText}" FontWeight="SemiBold" FontSize="16"/>
                                            <TextBlock Text="Supported Source" Foreground="{DynamicResource SecondaryText}" FontSize="12"/>
                                        </StackPanel>

                                        <!-- Col 3: Language Flags -->
                                        <ItemsControl Grid.Column="2" ItemsSource="{Binding LanguageFlags}" VerticalAlignment="Center" Margin="0,0,10,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="6"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="2" ClipToBounds="True">
                                                        <Image Source="{Binding}" Width="24" Height="16" Stretch="UniformToFill"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Col 4: Action / Status -->
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                             <!-- WebView Button (Open Browser for CAPTCHA) -->
                                             <Button x:CompileBindings="False"
                                                     Command="{Binding DataContext.OpenWebViewCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}}"
                                                     CommandParameter="{Binding}"
                                                     Background="Transparent" BorderThickness="0" Padding="6"
                                                     CornerRadius="16" Cursor="Hand"
                                                     ToolTip.Tip="Open in Browser (Solve CAPTCHA)">
                                                 <Button.Styles>
                                                     <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                         <Setter Property="Background" Value="#20FF9900"/>
                                                     </Style>
                                                 </Button.Styles>
                                                 <TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons" 
                                                            Foreground="{DynamicResource SecondaryText}" FontSize="16"
                                                            VerticalAlignment="Center"/>
                                             </Button>
                                             
                                             <!-- Arrow -->
                                             <TextBlock Text="&#xE76C;" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource SecondaryText}" FontSize="16" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
                <!-- Empty State (Online but no sources found) -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20" IsVisible="{Binding !HasSources}">
                    <TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons" FontSize="64" Foreground="#45475A" HorizontalAlignment="Center"/>
                    <StackPanel Spacing="8">
                        <TextBlock Text="No Sources Found" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Try changing the language filter to see more sources." Foreground="{DynamicResource SecondaryText}" FontSize="14" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Panel>
        </Grid>

        <!-- Offline State -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20" IsVisible="{Binding IsOffline}">
            <TextBlock Text="&#xEB55;" FontFamily="Segoe Fluent Icons" FontSize="64" Foreground="#F38BA8" HorizontalAlignment="Center"/>
            <StackPanel Spacing="8">
                <TextBlock Text="No Internet Connection" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center"/>
                <TextBlock Text="You are currently offline. Please check your network settings." Foreground="{DynamicResource SecondaryText}" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <!-- CAPTCHA Bypass Loading Overlay -->
        <Border Background="#90000000" IsVisible="{Binding IsBypassing}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                <helpers:LoadingArcs Margin="0,0,0,10"/>
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding BypassMessage}" 
                               Foreground="White" FontSize="18" FontWeight="SemiBold" 
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Please do not close the browser window until finished." 
                               Foreground="#B0FFFFFF" FontSize="12" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Panel>
</UserControl>
