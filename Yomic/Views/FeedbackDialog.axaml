<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Yomic.ViewModels"
        mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="350"
        x:Class="Yomic.Views.FeedbackDialog"
        Width="480" Height="400"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        ShowInTaskbar="False"
        CanResize="False"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        x:DataType="vm:FeedbackDialogViewModel"
        x:Name="FeedbackWindow">

    <Border Background="{DynamicResource PrimaryBackground}" CornerRadius="16" BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="1" Padding="24">
        <Grid RowDefinitions="Auto, *, Auto, Auto, Auto">
            
            <!-- Header -->
            <TextBlock Grid.Row="0" Text="Send feedback" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,20"/>
            
            <!-- Input Area -->
            <TextBox Grid.Row="1" 
                     Text="{Binding FeedbackText}"
                     Watermark="Tell us about your experience using this app..."
                     Background="{DynamicResource SidebarBackground}"
                     Foreground="{DynamicResource PrimaryText}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     CornerRadius="8"
                     BorderThickness="0"
                     Padding="12"
                     FontSize="14"
                     VerticalContentAlignment="Top">
                 <TextBox.Styles>
                     <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                         <Setter Property="Background" Value="{DynamicResource SidebarBackground}"/>
                         <Setter Property="BorderThickness" Value="0"/>
                     </Style>
                     <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                         <Setter Property="Background" Value="{DynamicResource SidebarBackground}"/>
                         <Setter Property="BorderThickness" Value="0"/>
                     </Style>
                 </TextBox.Styles>
            </TextBox>

            <!-- Screenshot Attachment -->
            <StackPanel Grid.Row="2" Margin="0,12,0,0" Spacing="8">
                <Button Command="{Binding AttachScreenshotCommand}"
                        IsVisible="{Binding CanAttachMoreScreenshots}"
                        Background="{DynamicResource SidebarBackground}"
                        Foreground="{DynamicResource PrimaryText}"
                        CornerRadius="8"
                        Padding="10,7"
                        HorizontalAlignment="Left"
                        BorderThickness="0">
                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                        </Style>
                    </Button.Styles>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="&#xE722;" FontFamily="Segoe Fluent Icons" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding AttachScreenshotText}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <ItemsControl ItemsSource="{Binding ScreenshotAttachments}" IsVisible="{Binding HasScreenshot}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:FeedbackScreenshotAttachment}">
                            <Border Background="{DynamicResource SidebarBackground}"
                                    CornerRadius="8"
                                    Padding="10,7"
                                    Margin="0,0,8,6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="&#xE8A7;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{DynamicResource SuccessColor}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding FileName}" FontSize="12" Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center"/>
                                    <Button x:CompileBindings="False"
                                            Command="{Binding DataContext.RemoveScreenshotCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="4"
                                            Foreground="{DynamicResource ErrorColor}"
                                            ToolTip.Tip="Remove screenshot">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="12"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Privacy Text -->
            <TextBlock Grid.Row="3" Margin="0,16,0,20" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryText}" FontSize="13" LineHeight="18">
                Your feedback is anonymous and helps us improve Yomic. Only your message and attached screenshots will be sent. Your personal messages and library stay private on your device.
            </TextBlock>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="16">
                <!-- Cancel Button -->
                <Button Content="Cancel" 
                        Command="{Binding CancelCommand}"
                        CommandParameter="{Binding ElementName=FeedbackWindow}"
                        Background="{DynamicResource HoverBackground}" 
                        Foreground="{DynamicResource PrimaryText}" 
                        CornerRadius="20"
                        Padding="24,10"
                        FontWeight="SemiBold"
                        FontSize="14"
                        Cursor="Hand"
                        BorderThickness="0">
                     <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource SeparatorBrush}"/>
                        </Style>
                    </Button.Styles>
                </Button>
                
                <!-- Submit Button -->
                <Button Content="Submit" 
                        Command="{Binding SubmitCommand}"
                        CommandParameter="{Binding ElementName=FeedbackWindow}"
                        Background="{DynamicResource AccentColor}" 
                        Foreground="White" 
                        CornerRadius="20" 
                        Padding="24,10"
                        FontWeight="SemiBold"
                        FontSize="14"
                        Cursor="Hand"
                        BorderThickness="0">
                     <Button.Styles>
                        <Style Selector="Button:disabled">
                            <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
                            <Setter Property="Opacity" Value="0.65"/>
                        </Style>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="{Binding $parent[Button].Background}"/>
                            <Setter Property="Foreground" Value="{Binding $parent[Button].Foreground}"/>
                        </Style>
                    </Button.Styles>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
