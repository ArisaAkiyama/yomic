<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Yomic.ViewModels"
             xmlns:helpers="clr-namespace:Yomic.Views.Helpers"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="Yomic.Views.SourceFeedView"
             x:DataType="vm:SourceFeedViewModel"
             Background="{DynamicResource PrimaryBackground}">
             
    <UserControl.Styles>
        <Style Selector="Button.BackBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <BrushTransition Property="Foreground" Duration="0:0:0.2"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.BackBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
        </Style>
        <Style Selector="Button.BackBtn:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.05)"/>
        </Style>
        
        <!-- Card Style same as Library -->
        <Style Selector="Border.MangaCard">
            <Setter Property="ZIndex" Value="1"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.MangaCard:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.02) translateY(-4px)"/>
            <Setter Property="ZIndex" Value="10"/>
            <Setter Property="BoxShadow" Value="0 10 20 0 #60000000"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <!-- Pagination Button Style -->
        <Style Selector="Button.PageBtn">
            <Setter Property="Background" Value="{DynamicResource SidebarBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15,8"/>
        </Style>
         <Style Selector="Button.PageBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        </Style>
        <Style Selector="Button.PageBtn:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SidebarBackground}"/>
             <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
        </Style>

        <!-- Standard Header Action Button Style -->
        <Style Selector="Button.header-action">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
        </Style>
        <Style Selector="Button.header-action:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#15FFFFFF"/>
        </Style>
        <Style Selector="Button.header-action:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        </Style>
        <Style Selector="Button.header-action:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#25FFFFFF"/>
        </Style>

        <!-- Disable transitions for header buttons to avoid color "lag" -->
        <Style Selector="Button.header-action TextBlock">
             <Setter Property="Transitions" Value="{x:Null}"/>
        </Style>

        <Style Selector="Button.header-action.accent">
            <Setter Property="Foreground" Value="#0078D7"/>
        </Style>
        <Style Selector="Button.header-action.accent:pointerover">
            <Setter Property="Foreground" Value="#3395FF"/>
        </Style>


    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *, Auto">
        <!-- Header / Search Bar -->
        <Border Grid.Row="0" Padding="20" Background="{DynamicResource PrimaryBackground}">
            <StackPanel>
                 <!-- Title Row -->
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
                    <Button Command="{Binding BackCommand}" Classes="BackBtn">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe Fluent Icons" FontSize="20" VerticalAlignment="Center"/>
                    </Button>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Browse Source" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                        <TextBlock Text="-" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SourceName}" FontSize="28" FontWeight="Bold" Foreground="#0078D7" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                 <!-- Search & Filter Row (Similar to Library) -->
                <Grid ColumnDefinitions="*, Auto, Auto">
                    <!-- Modern Enhanced Search Bar (Library Style) -->
                     <TextBox Grid.Column="0" Width="350" HorizontalAlignment="Left"
                              x:Name="SearchBox"
                              Watermark="Search manga..." CornerRadius="20"
                              Text="{Binding SearchText}"
                              Background="{DynamicResource SidebarBackground}" Foreground="{DynamicResource PrimaryText}" BorderThickness="0"
                              Padding="15,10" VerticalContentAlignment="Center">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}"/>
                        </TextBox.KeyBindings>
                        <TextBox.Styles>
                            <!-- Match Library View Focus Styles -->
                            <Style Selector="TextBox:focus">
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                                <Setter Property="CaretBrush" Value="{DynamicResource PrimaryText}"/>
                            </Style>
                            <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="{DynamicResource SidebarBackground}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                            <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                             <Style Selector="TextBox:pointerover">
                                 <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                             </Style>
                             
                             <!-- Watermark -->
                             <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
                                 <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
                             </Style>
                             <Style Selector="TextBox:focus /template/ TextBlock#PART_Watermark">
                                 <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
                             </Style>
                             <Style Selector="TextBox:pointerover /template/ TextBlock#PART_Watermark">
                                 <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
                             </Style>
                        </TextBox.Styles>
                        
                        <TextBox.InnerRightContent>
                            <Button Command="{Binding SearchCommand}" 
                                    Background="Transparent" BorderThickness="0" 
                                    Padding="0" Margin="0,0,10,0" Cursor="Hand">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                    <Style Selector="Button:pressed /template/ ContentPresenter">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                    <Style Selector="Button:pressed TextBlock">
                                        <Setter Property="Opacity" Value="0.7"/>
                                    </Style>
                                </Button.Styles>
                                <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource SecondaryText}" 
                                           VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock.Transitions>
                                        <Transitions>
                                            <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
                                        </Transitions>
                                    </TextBlock.Transitions>
                                </TextBlock>
                            </Button>
                        </TextBox.InnerRightContent>
                    </TextBox>
                    
                    <!-- Buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="10,0,0,0">
                        <!-- Refresh Button -->
                        <Button Command="{Binding RefreshCommand}" 
                                Classes="header-action"
                                ToolTip.Tip="Refresh (Bypass Cache)">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons" FontSize="18" VerticalAlignment="Center"/>
                        </Button>

                        <!-- Language Toggle (Flag Only) - MangaDex Only -->
                        <Button Command="{Binding ToggleLanguageCommand}" 
                                IsVisible="{Binding IsMangaDex}"
                                Background="Transparent" Padding="4"
                                CornerRadius="4"
                                ToolTip.Tip="Toggle Language: English / Indonesian">
                            <Button.Styles>
                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#15FFFFFF"/>
                                </Style>
                            </Button.Styles>
                            <Image Source="{Binding LanguageFlagBitmap}" Width="24" Height="16" Stretch="Uniform"/>
                        </Button>

                        <!-- Latest Updates Toggle -->
                        <Button Command="{Binding LatestModeCommand}" 
                                Classes="header-action"
                                Classes.accent="{Binding IsLatestMode}"
                                ToolTip.Tip="Toggle Latest Updates">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="&#xE823;" FontFamily="Segoe Fluent Icons" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Latest" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="14"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Panel Grid.Row="1">


            <!-- content wrapper -->
             <!-- Removed ScrollViewer to allow virtualized ListBox to handle scrolling -->
             <Grid>
                 <Grid.RowDefinitions>
                     <RowDefinition Height="Auto"/> <!-- Error Message -->
                     <RowDefinition Height="*"/>    <!-- List -->
                     <RowDefinition Height="Auto"/> <!-- Footer -->
                 </Grid.RowDefinitions>
                 
                 <!-- Error Message / Extension Update Banner -->
                 <Border Grid.Row="0" Background="#1E1E2E" BorderBrush="#313244" BorderThickness="1" CornerRadius="12" Padding="25" Margin="40,20,40,20" VerticalAlignment="Top" ZIndex="5" HorizontalAlignment="Stretch" MaxWidth="800">
                     <Border.IsVisible>
                         <MultiBinding Converter="{x:Static BoolConverters.And}">
                             <Binding Path="HasError"/>
                             <Binding Path="IsMangaDexBlocked" Converter="{x:Static BoolConverters.Not}"/>
                         </MultiBinding>
                     </Border.IsVisible>
                     <StackPanel Spacing="0">
                          <!-- Header -->
                          <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,15">
                              <TextBlock Text="&#xE8FD;" FontFamily="Segoe Fluent Icons" FontSize="20" Foreground="#0078D7" VerticalAlignment="Center"/>
                              <TextBlock Text="Mengalami kendala pada Extension?" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                          </StackPanel>
                          
                          <!-- Message -->
                          <TextBlock Text="Cek dan download versi terbaru di repository kami. Jika masalah berlanjut, silakan kirim Feedback." 
                                     Foreground="{DynamicResource SecondaryText}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,25" LineHeight="22"/>
                          
                          <!-- Technical Error Log (Optional, dimmed) -->
                          <TextBlock Text="{Binding ErrorMessage}" Foreground="#5C5F77" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,20" MaxLines="2" TextTrimming="CharacterEllipsis"/>

                          <!-- Buttons -->
                          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="15">
                              <!-- Close Button -->
                              <Button Command="{Binding CloseErrorCommand}" 
                                      Background="Transparent" Foreground="{DynamicResource SecondaryText}" 
                                      CornerRadius="6" Padding="15,8" Cursor="Hand" BorderThickness="0">
                                   <Button.Styles>
                                       <Style Selector="Button:pointerover /template/ ContentPresenter">
                                           <Setter Property="Background" Value="#15FFFFFF"/>
                                           <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                                       </Style>
                                   </Button.Styles>
                                  <TextBlock Text="Tutup" FontWeight="SemiBold"/>
                              </Button>

                              <!-- Contact Dev Button -->
                              <Button Command="{Binding ContactDevCommand}" 
                                      Background="Transparent" BorderBrush="#0078D7" BorderThickness="1" 
                                      CornerRadius="8" Padding="15,8" Cursor="Hand">
                                  <Button.Styles>
                                       <Style Selector="Button:pointerover /template/ ContentPresenter">
                                           <Setter Property="Background" Value="#1A0078D7"/>
                                       </Style>
                                  </Button.Styles>
                                  <StackPanel Orientation="Horizontal" Spacing="8">
                                      <TextBlock Text="&#xE715;" FontFamily="Segoe Fluent Icons" Foreground="#0078D7" FontSize="16" VerticalAlignment="Center"/>
                                      <TextBlock Text="Send Feedback" Foreground="#0078D7" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                  </StackPanel>
                              </Button>

                              <!-- Download Update Button -->
                              <Button Command="{Binding DownloadUpdateCommand}" 
                                      Background="#0078D7" BorderThickness="0" 
                                      CornerRadius="8" Padding="20,8" Cursor="Hand">
                                  <Button.Styles>
                                       <Style Selector="Button:pointerover /template/ ContentPresenter">
                                           <Setter Property="Background" Value="#3395FF"/>
                                       </Style>
                                  </Button.Styles>
                                  <StackPanel Orientation="Horizontal" Spacing="8">
                                      <TextBlock Text="&#xE896;" FontFamily="Segoe Fluent Icons" Foreground="White" FontSize="16" VerticalAlignment="Center"/>
                                      <TextBlock Text="Download Update" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                  </StackPanel>
                              </Button>
                          </StackPanel>
                     </StackPanel>
                 </Border>

                 <!-- BLOCKED STATE UI (MangaDex) -->
                 <Border Grid.Row="1" Background="#1E1E2E" IsVisible="{Binding IsMangaDexBlocked}" ZIndex="20" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                     <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                         <TextBlock Text="&#xE730;" FontFamily="Segoe Fluent Icons" FontSize="64" Foreground="#F38BA8" HorizontalAlignment="Center"/>
                         <TextBlock Text="MangaDex is Blocked" FontSize="24" FontWeight="Bold" Foreground="#F38BA8" HorizontalAlignment="Center"/>
                         <TextBlock Text="It seems your network is blocking access to MangaDex." Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center"/>
                         
                         <Border Background="#313244" CornerRadius="8" Padding="20" MaxWidth="400">
                             <StackPanel Spacing="10">
                                 <TextBlock Text="Recommended Solutions:" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"/>
                                 <StackPanel Orientation="Horizontal" Spacing="10">
                                     <TextBlock Text="1." Foreground="{DynamicResource SecondaryText}"/>
                                     <TextBlock Text="Enable VPN (Cloudflare WARP or similar)" Foreground="{DynamicResource PrimaryText}"/>
                                 </StackPanel>
                                 <StackPanel Orientation="Horizontal" Spacing="10">
                                     <TextBlock Text="2." Foreground="{DynamicResource SecondaryText}"/>
                                     <TextBlock Text="Change DNS to 1.1.1.1 or 8.8.8.8" Foreground="{DynamicResource PrimaryText}"/>
                                 </StackPanel>
                             </StackPanel>
                         </Border>
                         
                         <Button Command="{Binding RefreshCommand}" 
                                 Content="Try Again"
                                 HorizontalAlignment="Center"
                                 Classes="PageBtn"
                                 Background="#0078D7" Foreground="#FFFFFF"/>
                     </StackPanel>
                 </Border>

                 <!-- Empty State (No Results / Bad Connection) -->
                 <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                     <StackPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="IsSourceEmpty"/>
                            <Binding Path="!IsLoading"/>
                            <Binding Path="!IsBusy"/>
                            <Binding Path="!HasError"/>
                        </MultiBinding>
                     </StackPanel.IsVisible>

                    <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons" FontSize="48" Foreground="#45475A" HorizontalAlignment="Center"/>
                    <TextBlock Text="Manga Tidak Ditemukan" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Sepertinya koneksi jaringan sedang tidak baik (Cloudflare/Error). Silakan refresh." FontSize="16" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center"/>
                 </StackPanel>

                 <!-- Virtualized Items List -->
                 <!-- Use ListBox for virtualization support -->
                 <ListBox x:Name="MangaListBox" Grid.Row="1" ItemsSource="{Binding MangaList}" Background="Transparent" 
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          Margin="20,0,0,0" Padding="0,0,0,20">
                     <ListBox.ItemsPanel>
                         <ItemsPanelTemplate>
                             <WrapPanel Orientation="Horizontal" ItemWidth="175" ItemHeight="310"/>
                         </ItemsPanelTemplate>
                     </ListBox.ItemsPanel>
                     
                     <ListBox.Styles>
                         <Style Selector="ListBoxItem">
                             <Setter Property="Padding" Value="0"/>
                             <Setter Property="Margin" Value="0"/>
                             <Setter Property="Background" Value="Transparent"/>
                         </Style>
                         <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                             <Setter Property="Background" Value="Transparent"/>
                         </Style>
                         <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                             <Setter Property="Background" Value="Transparent"/>
                         </Style>
                     </ListBox.Styles>

                     <ListBox.ItemTemplate>
                         <DataTemplate>
                              <Button x:CompileBindings="False" Background="Transparent" Padding="0" Margin="10,0,10,20"
                                      Command="{Binding DataContext.OpenMangaCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}}"
                                      CommandParameter="{Binding}">
                                  <Button.Styles>
                                     <Style Selector="Button:pointerover /template/ ContentPresenter">
                                         <Setter Property="Background" Value="Transparent"/>
                                     </Style>
                                  </Button.Styles>
                                  
                                 <StackPanel Width="150" Spacing="10">
                                     <!-- Cover Image -->
                                     <Border Classes="MangaCard" Height="225" CornerRadius="12" 
                                             Background="{DynamicResource SidebarBackground}" ClipToBounds="True"
                                             BoxShadow="0 4 10 0 #40000000">
                                         <Grid>
                                             <Image helpers:SecureImageLoader.Url="{Binding CoverUrl}" Stretch="UniformToFill"/>
                                             
                                             <!-- Status Badge (Top-Left) -->
                                             <Border VerticalAlignment="Top" HorizontalAlignment="Left" 
                                                     Margin="8" Padding="6,2" CornerRadius="6"
                                                     Background="{Binding StatusString, Converter={x:Static vm:StatusToColorConverter.Instance}}"
                                                     IsVisible="{Binding Status, Converter={x:Static vm:StatusToColorConverter.StatusToVisibility}}">
                                                 <TextBlock Text="{Binding StatusString}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                             </Border>

                                             <!-- Time Overlay (Bottom) -->
                                             <Panel VerticalAlignment="Bottom" IsVisible="{Binding LastUpdateString, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                 <!-- Gradient Shadow for readability -->
                                                 <Border Height="60" VerticalAlignment="Bottom">
                                                     <Border.Background>
                                                         <LinearGradientBrush StartPoint="50%,0%" EndPoint="50%,100%">
                                                             <GradientStop Offset="0" Color="#00000000"/>
                                                             <GradientStop Offset="1" Color="#D0000000"/>
                                                         </LinearGradientBrush>
                                                     </Border.Background>
                                                 </Border>
                                                 
                                                 <!-- Text -->
                                                 <StackPanel Orientation="Horizontal" Spacing="4" Margin="10,0,10,10" VerticalAlignment="Bottom">
                                                     <TextBlock Text="&#xE916;" FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="#0078D7" VerticalAlignment="Center"/>
                                                     <TextBlock Text="{Binding LastUpdateString}" Foreground="#0078D7" 
                                                                FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                                 </StackPanel>
                                             </Panel>
                                         </Grid>
                                     </Border>
                                     
                                     <!-- Title Below Image -->
                                     <TextBlock Text="{Binding Title}" Foreground="{DynamicResource PrimaryText}" 
                                                TextAlignment="Left" TextTrimming="CharacterEllipsis"
                                                FontSize="14" FontWeight="Medium" MaxLines="2" Height="40"/>
                                 </StackPanel>
                              </Button>
                         </DataTemplate>
                     </ListBox.ItemTemplate>
                 </ListBox>
                    
                    <!-- Pagination Controls (Footer) -->
                    <!-- Moved here so it scrolls with content -->
                    <Border Grid.Row="2" IsVisible="{Binding IsPaginationVisible}"
                            Background="Transparent" 
                            Padding="10,10" Margin="0,5,0,10" HorizontalAlignment="Stretch">
                        <Grid ColumnDefinitions="Auto, *, Auto" MaxWidth="800" HorizontalAlignment="Center">
                            <!-- Prev Button -->
                            <Button Grid.Column="0" 
                                    Command="{Binding PrevPageCommand}" 
                                    Classes="PageBtn"
                                    IsEnabled="{Binding HasPrevPage}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="&#xE892;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center"/>
                                    <TextBlock Text="Previous" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
    
                            <!-- Page Info Button with Flyout -->
                            <Button Grid.Column="1" 
                                    Content="{Binding PageInfo}" 
                                    Foreground="#0078D7" 
                                    FontWeight="Bold" 
                                    FontSize="14"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Center"
                                    Margin="20,0"
                                    Cursor="Hand"
                                    ToolTip.Tip="Jump to a specific page">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="#15FFFFFF"/>
                                        <Setter Property="Foreground" Value="#3395FF"/>
                                    </Style>
                                </Button.Styles>
                                <Button.Flyout>
                                    <Flyout Placement="Top">
                                        <Border Background="#1E1E2E" CornerRadius="8" Padding="15" BorderBrush="#313244" BorderThickness="1" BoxShadow="0 8 20 0 #60000000">
                                            <StackPanel Spacing="12">
                                                <TextBlock Text="Go to page:" Foreground="{DynamicResource PrimaryText}" FontWeight="SemiBold" FontSize="14"/>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBox Width="100" 
                                                             Text="{Binding TargetPageInput}" 
                                                             Watermark="Page #"
                                                             CornerRadius="6"
                                                             Background="#313244"
                                                             Foreground="{DynamicResource PrimaryText}"
                                                             BorderThickness="1" BorderBrush="#45475A">
                                                        <TextBox.KeyBindings>
                                                            <KeyBinding Gesture="Enter" Command="{Binding GoToPageCommand}"/>
                                                        </TextBox.KeyBindings>
                                                    </TextBox>
                                                    <Button Content="Go" 
                                                            Command="{Binding GoToPageCommand}"
                                                            Background="#0078D7" 
                                                            Foreground="White" 
                                                            FontWeight="Bold" 
                                                            CornerRadius="6" 
                                                            Padding="12,6">
                                                        <Button.Styles>
                                                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                                <Setter Property="Background" Value="#3395FF"/>
                                                            </Style>
                                                        </Button.Styles>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
    
                            <!-- Next Button -->
                            <Button Grid.Column="2" 
                                    Command="{Binding NextPageCommand}" 
                                    Classes="PageBtn"
                                    IsEnabled="{Binding HasNextPage}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Next" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Text="&#xE893;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                     </Border>
                 </Grid>
             <!-- </StackPanel> -->
             <!-- </ScrollViewer> -->
        </Panel>

        <!-- Sync Overlay -->
        <Border Grid.RowSpan="3" Background="#80000000" IsVisible="{Binding IsBusy}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="15">
                 <ProgressBar IsIndeterminate="True" Foreground="{DynamicResource AccentColor}" Width="150" Height="2" Background="#33FFFFFF"/>
                 <TextBlock Text="Loading..." Foreground="White" HorizontalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
