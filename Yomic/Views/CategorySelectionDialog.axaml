<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Yomic.Views.CategorySelectionDialog"
        Width="350" Height="400"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        ShowInTaskbar="False"
        CanResize="False"
        Background="Transparent"
        TransparencyLevelHint="Transparent">

    <Border Background="{DynamicResource PrimaryBackground}" CornerRadius="16" BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="1" Padding="24">
        <Grid RowDefinitions="Auto, *, Auto">
            <!-- Header -->
            <TextBlock Grid.Row="0" Text="Edit Categories" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,16"/>
            
            <!-- Category List -->
            <ScrollViewer Grid.Row="1" Margin="0,0,0,16">
                <StackPanel x:Name="CategoriesStack" Spacing="4">
                    <!-- Dynamic Checkboxes populated in code-behind -->
                </StackPanel>
            </ScrollViewer>
            
            <!-- Actions -->
            <Grid Grid.Row="2" ColumnDefinitions="*, *">
                <Button Grid.Column="0" Content="Cancel" Click="OnCancelClick" 
                        HorizontalAlignment="Left" HorizontalContentAlignment="Center"
                        Background="Transparent" Foreground="{DynamicResource PrimaryText}" FontWeight="SemiBold"
                        CornerRadius="8" Padding="20,10" Cursor="Hand" BorderThickness="0">
                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                        </Style>
                    </Button.Styles>
                </Button>
                <Button Grid.Column="1" Content="Save" Click="OnSaveClick"
                        HorizontalAlignment="Right" HorizontalContentAlignment="Center"
                        Background="{DynamicResource PrimaryAccent}" Foreground="White" FontWeight="SemiBold"
                        CornerRadius="8" Padding="20,10" Cursor="Hand" BorderThickness="0">
                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#0066B8"/>
                        </Style>
                    </Button.Styles>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
