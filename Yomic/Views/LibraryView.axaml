<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Yomic.ViewModels"
             xmlns:views="using:Yomic.Views"
             xmlns:helpers="clr-namespace:Yomic.Views.Helpers"
             x:Class="Yomic.Views.LibraryView"
             x:Name="root"
             x:DataType="vm:LibraryViewModel"
             Background="{DynamicResource PrimaryBackground}">
    
    <UserControl.Styles>
        <Style Selector="Border.MangaCard">
            <Setter Property="ZIndex" Value="1"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.MangaCard:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.02) translateY(-4px)"/>
            <Setter Property="ZIndex" Value="10"/>
            <Setter Property="BoxShadow" Value="0 10 20 0 #60000000"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <!-- TextBox style: black text on focus (when background becomes white) -->
        <!-- TextBox style: keep dark on focus and hover -->
        <Style Selector="TextBox:focus">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryText}"/>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
             <Setter Property="Background" Value="{DynamicResource SidebarBackground}"/>
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
             <Setter Property="Background" Value="{DynamicResource SidebarBackground}"/>
        </Style>
        <Style Selector="TextBox:focus /template/ TextBlock#PART_Watermark">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
        </Style>




        <!-- Standard Header Action Button Style -->
        <Style Selector="Button.header-action">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
        </Style>
        <Style Selector="Button.header-action:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#15FFFFFF"/>
        </Style>
        <Style Selector="Button.header-action:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        </Style>
        <Style Selector="Button.header-action:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#25FFFFFF"/>
        </Style>

        <!-- Disable transitions for header buttons to avoid color "lag" -->
        <Style Selector="Button.header-action TextBlock">
             <Setter Property="Transitions" Value="{x:Null}"/>
        </Style>

        <!-- Source Filter Tab Style (Segmented Tabs) -->
        <Style Selector="ListBox#SourceTabsListBox">
            <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="3"/>
        </Style>
        <Style Selector="#SourceTabsListBox ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                    <BrushTransition Property="Foreground" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="#SourceTabsListBox ListBoxItem:pointerover /template/ Border">
            <Setter Property="Background" Value="#0AFFFFFF"/>
        </Style>
        <Style Selector="#SourceTabsListBox ListBoxItem:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        </Style>
        <Style Selector="#SourceTabsListBox ListBoxItem:selected /template/ Border">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BoxShadow" Value="0 1 3 0 #18000000"/>
        </Style>
        <Style Selector="#SourceTabsListBox ListBoxItem:selected">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Scroll Button Style -->
        <Style Selector="Button.scroll-button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.scroll-button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#15FFFFFF"/>
        </Style>
        <Style Selector="Button.scroll-button TextBlock">
             <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
        </Style>
        <Style Selector="Button.scroll-button:pointerover TextBlock">
             <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        </Style>
        
        <!-- Category Tabs ListBox Style -->
        <Style Selector="ListBox#CategoryTabsListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="ListBox#CategoryTabsListBox ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="ListBox#CategoryTabsListBox ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBox#CategoryTabsListBox ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </UserControl.Styles>
    
    <Panel>
        <Grid RowDefinitions="Auto, *">
            <StackPanel Grid.Row="0" Margin="30,25,30,15">
                <!-- Row 0: Title + Badge + Actions -->
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <!-- Header Icon -->
                        <TextBlock Text="&#xE8F1;" FontFamily="Segoe Fluent Icons" FontSize="24" 
                                   Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"
                                   RenderOptions.TextRenderingMode="Antialias"/>
                                   
                        <TextBlock Text="Library" FontSize="28" FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                        

                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                        <!-- Filter Button -->
                        <Button Classes="header-action" ToolTip.Tip="Sort and Filter">
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                    <!-- Filter Section -->
                                    <MenuItem Header="Filter by">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE71C;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center"/>
                                        </MenuItem.Icon>
                                        <MenuItem Header="Show All" Command="{Binding SetFilterModeCommand}" CommandParameter="{x:Static vm:LibraryFilterMode.All}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons"
                                                           IsVisible="{Binding SelectedFilterMode, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:LibraryFilterMode.All}}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Unread Only" Command="{Binding SetFilterModeCommand}" CommandParameter="{x:Static vm:LibraryFilterMode.UnreadOnly}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons"
                                                           IsVisible="{Binding SelectedFilterMode, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:LibraryFilterMode.UnreadOnly}}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Ongoing Only" Command="{Binding SetFilterModeCommand}" CommandParameter="{x:Static vm:LibraryFilterMode.OngoingOnly}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons"
                                                           IsVisible="{Binding SelectedFilterMode, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:LibraryFilterMode.OngoingOnly}}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Completed Only" Command="{Binding SetFilterModeCommand}" CommandParameter="{x:Static vm:LibraryFilterMode.CompletedOnly}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons"
                                                           IsVisible="{Binding SelectedFilterMode, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:LibraryFilterMode.CompletedOnly}}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Downloaded Only" Command="{Binding SetFilterModeCommand}" CommandParameter="{x:Static vm:LibraryFilterMode.DownloadedOnly}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons"
                                                           IsVisible="{Binding SelectedFilterMode, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:LibraryFilterMode.DownloadedOnly}}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </MenuItem>

                                    <!-- Browse By Section -->
                                    <MenuItem Header="Browse by" ItemsSource="{Binding AvailableSources}">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center"/>
                                        </MenuItem.Icon>
                                        <MenuItem.Styles>
                                            <Style Selector="MenuItem > MenuItem" x:DataType="vm:LibraryViewModel+LibrarySourceFilterItem">
                                                <Setter Property="Command" Value="{Binding $parent[UserControl].((vm:LibraryViewModel)DataContext).SetSourceFilterCommand}"/>
                                                <Setter Property="CommandParameter" Value="{Binding Name}"/>
                                            </Style>
                                        </MenuItem.Styles>
                                        <MenuItem.ItemTemplate>
                                            <DataTemplate DataType="vm:LibraryViewModel+LibrarySourceFilterItem" x:CompileBindings="False">
                                                <Grid ColumnDefinitions="24, 24, *">
                                                    <TextBlock Grid.Column="0" Text="&#xE73E;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center">
                                                        <TextBlock.IsVisible>
                                                            <MultiBinding Converter="{x:Static vm:StatusToColorConverter.StringEqualityConverter}">
                                                                <Binding Path="$parent[UserControl].DataContext.SelectedSourceFilter" />
                                                                <Binding Path="Name" />
                                                            </MultiBinding>
                                                        </TextBlock.IsVisible>
                                                    </TextBlock>
                                                    <!-- Icon -->
                                                    <Border Grid.Column="1" Width="18" Height="18" Margin="0,0,6,0" CornerRadius="4" Background="{Binding IconColor}" ClipToBounds="True" VerticalAlignment="Center" IsVisible="{Binding Name, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                        <Panel>
                                                            <TextBlock Text="{Binding IconText}" Foreground="{Binding IconForeground}" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding IconText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                            <Image Source="{Binding IconBitmap}" Stretch="UniformToFill" RenderOptions.BitmapInterpolationMode="HighQuality" IsVisible="{Binding IconBitmap, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                        </Panel>
                                                    </Border>
                                                    <TextBlock Grid.Column="2" Text="{Binding Name}" VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </MenuItem.ItemTemplate>
                                    </MenuItem>

                                    <!-- Sort Section -->
                                    <MenuItem Header="Sort by">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE8CB;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center"/>
                                        </MenuItem.Icon>
                                        <MenuItem Header="Last Read (Recently)" Command="{Binding SetSortModeCommand}" CommandParameter="{x:Static vm:LibrarySortMode.LastReadDesc}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons"
                                                           IsVisible="{Binding SelectedSortMode, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:LibrarySortMode.LastReadDesc}}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Most Unread" Command="{Binding SetSortModeCommand}" CommandParameter="{x:Static vm:LibrarySortMode.UnreadCountDesc}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons"
                                                           IsVisible="{Binding SelectedSortMode, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:LibrarySortMode.UnreadCountDesc}}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Date Modified" Command="{Binding SetSortModeCommand}" CommandParameter="{x:Static vm:LibrarySortMode.DateModified}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons"
                                                           IsVisible="{Binding SelectedSortMode, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:LibrarySortMode.DateModified}}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="A → Z" Command="{Binding SetSortModeCommand}" CommandParameter="{x:Static vm:LibrarySortMode.TitleAsc}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons"
                                                           IsVisible="{Binding SelectedSortMode, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:LibrarySortMode.TitleAsc}}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Z → A" Command="{Binding SetSortModeCommand}" CommandParameter="{x:Static vm:LibrarySortMode.TitleDesc}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons"
                                                           IsVisible="{Binding SelectedSortMode, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:LibrarySortMode.TitleDesc}}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="Manage Categories..." Command="{Binding ManageCategoriesCommand}">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </MenuFlyout>
                            </Button.Flyout>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="&#xE71C;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Filter" VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>
                            </StackPanel>
                        </Button>
                        
                        <!-- Refresh Button -->
                        <Button Command="{Binding RefreshCommand}"
                                IsEnabled="{Binding IsOnline}"
                                Classes="header-action"
                                ToolTip.Tip="Sync Library">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons" 
                                           FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        
                        <!-- Toggle View Mode Button -->
                        <Button Command="{Binding ToggleViewModeCommand}"
                                Classes="header-action"
                                ToolTip.Tip="Toggle View Mode (Grid/List)">
                                <Panel>
                                    <TextBlock Text="&#xE8FD;" FontFamily="Segoe Fluent Icons" 
                                               FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               IsVisible="{Binding !IsListView}"/>
                                    <TextBlock Text="&#xE8A9;" FontFamily="Segoe Fluent Icons" 
                                               FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               IsVisible="{Binding IsListView}"/>
                                </Panel>
                        </Button>
                    </StackPanel>
                </Grid>



                <!-- Row 1: Search + Source Tabs -->
                <Grid ColumnDefinitions="Auto, *" Margin="0,18,0,0">
                    <TextBox Width="300" HorizontalAlignment="Left"
                             Watermark="Search library..." CornerRadius="20"
                             Text="{Binding SearchText}"
                             Background="{DynamicResource SidebarBackground}" Foreground="{DynamicResource PrimaryText}" BorderThickness="0"
                             Padding="8,8,15,8" VerticalContentAlignment="Center" FontSize="13">
                        <TextBox.InnerLeftContent>
                             <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource SecondaryText}" 
                                        VerticalAlignment="Center" Margin="12,0,0,0" FontSize="14"/>
                        </TextBox.InnerLeftContent>
                    </TextBox>

                    <!-- Removed SourceTabsScrollViewer as it is now in the Filter Menu -->
                </Grid>
                
                <!-- Category Tabs -->
                <Grid ColumnDefinitions="*, Auto" Margin="0,16,0,0" IsVisible="{Binding HasCategories}">
                    <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ListBox x:Name="CategoryTabsListBox" 
                                 ItemsSource="{Binding CategoryTabs}" 
                                 SelectedItem="{Binding SelectedCategoryTab}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="vm:CategoryTabItem">
                                    <Border Background="{Binding BackgroundBrush}" 
                                            CornerRadius="14" 
                                            BorderBrush="{DynamicResource SeparatorBrush}"
                                            BorderThickness="1"
                                            Padding="14,6"
                                            DragDrop.AllowDrop="True"
                                            DragDrop.DragOver="OnTabDragOver"
                                            DragDrop.Drop="OnTabDrop">
                                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <Ellipse Width="8" Height="8" Fill="{Binding ColorBrush}" IsVisible="{Binding ShowColorDot}"/>
                                            <TextBlock Text="{Binding Name}" Foreground="{Binding ForegroundBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                    <Button Grid.Column="1" Classes="header-action" Command="{Binding ManageCategoriesCommand}" VerticalAlignment="Center" ToolTip.Tip="Manage Categories" Margin="10,0,0,0">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons" FontSize="16"/>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- Virtualized ListBox -->
            <ListBox x:Name="LibraryListBox" Grid.Row="1" ItemsSource="{Binding LibraryItems}" 
                     Background="Transparent" BorderThickness="0" 
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     IsVisible="{Binding ShowGridView}">
                <ListBox.Styles>
                    <!-- Disable default ListBoxItem selection styles -->
                    <Style Selector="ListBoxItem">
                         <Setter Property="Padding" Value="0"/>
                         <Setter Property="Margin" Value="0"/>
                         <Setter Property="Background" Value="Transparent"/>
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </ListBox.Styles>

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" ItemWidth="175" ItemHeight="310" HorizontalAlignment="Center"/> 
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:MangaItem">
                         <Button x:CompileBindings="False" Background="Transparent" Padding="0" Margin="10,0,10,20"
                                 Command="{Binding DataContext.OpenMangaCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}}"
                                 CommandParameter="{Binding}">
                             <Button.Styles>
                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                             </Button.Styles>
                             
                                <StackPanel Width="150" Spacing="8">
                                <!-- Cover Image -->
                                <Border Classes="MangaCard" Height="225" CornerRadius="12" 
                                        Background="{DynamicResource SidebarBackground}" ClipToBounds="True"
                                        BoxShadow="0 4 10 0 #40000000"
                                        PointerPressed="OnMangaCardPointerPressed"
                                        PointerMoved="OnMangaCardPointerMoved"
                                        PointerReleased="OnMangaCardPointerReleased">
                                    
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Mark as Read"
                                                      x:CompileBindings="False"
                                                      Command="{Binding #root.DataContext.MarkAsReadCommand}"
                                                      CommandParameter="{Binding}"/>
                                            <MenuItem Header="Mark as Unread"
                                                      x:CompileBindings="False"
                                                      Command="{Binding #root.DataContext.MarkAsUnreadCommand}"
                                                      CommandParameter="{Binding}"/>
                                            <MenuItem Header="Edit Categories..."
                                                      x:CompileBindings="False"
                                                      Command="{Binding #root.DataContext.EditMangaCategoriesCommand}"
                                                      CommandParameter="{Binding}"/>
                                            <Separator/>
                                            <MenuItem Header="Remove from Library (Keep Files)"
                                                      x:CompileBindings="False"
                                                      Command="{Binding #root.DataContext.RemoveMangaCommand}"
                                                      CommandParameter="{Binding}"/>
                                            <MenuItem Header="Delete All Downloads" Foreground="#FF5555"
                                                      x:CompileBindings="False"
                                                      Command="{Binding #root.DataContext.DeleteMangaDownloadsCommand}"
                                                      CommandParameter="{Binding}"/>
                                            <MenuItem Header="Delete from Disk" Foreground="#FF5555"
                                                      x:CompileBindings="False"
                                                      Command="{Binding #root.DataContext.DeleteMangaCommand}"
                                                      CommandParameter="{Binding}"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                
                                    <Grid>
                                         <Image helpers:SecureImageLoader.Url="{Binding CoverUrl}" 
                                                Stretch="UniformToFill"/>
                                        
                                        <!-- NEW Badge (Top Left) -->
                                        <Border Background="#89B4FA" CornerRadius="6"
                                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                                Margin="8" Padding="6,2"
                                                IsVisible="{Binding IsNewBadgeVisible}">
                                            <TextBlock Text="NEW" Foreground="#1E1E2E"
                                                       FontSize="10" FontWeight="Bold"/>
                                        </Border>

                                        <!-- Unread Badge -->
                                        <Border Background="#0078D7" CornerRadius="6" 
                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Margin="8" Padding="6,2"
                                                IsVisible="{Binding UnreadCount, Converter={x:Static ObjectConverters.IsNotNull}}">
                                            <TextBlock Text="{Binding UnreadCount}" Foreground="#FFFFFF" 
                                                       FontSize="11" FontWeight="Bold"/>
                                        </Border>

                                        <!-- Download Badge (Bottom Right) -->
                                        <Border Background="#059669" CornerRadius="6" 
                                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                Margin="8" Padding="6,2"
                                                IsVisible="{Binding IsDownloadedBadgeVisible}">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="&#xE896;" FontFamily="Segoe Fluent Icons" Foreground="#FFFFFF" 
                                                            FontSize="9" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding DownloadedCount}" Foreground="#FFFFFF" 
                                                            FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                                
                                <!-- Title Below Image -->
                                <TextBlock Text="{Binding Title}" Foreground="{DynamicResource PrimaryText}" 
                                           TextAlignment="Left" TextTrimming="CharacterEllipsis"
                                           FontSize="13" FontWeight="SemiBold" MaxLines="2" Height="36"
                                           ToolTip.Tip="{Binding Title}"/>

                                <!-- Metadata: Source + Last Read -->
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,-4,0,0">
                                    <TextBlock Text="{Binding SourceName}" Foreground="{DynamicResource SecondaryText}" 
                                               FontSize="11" Opacity="0.7" MaxLines="1" TextTrimming="CharacterEllipsis"
                                               IsVisible="{Binding SourceName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    <TextBlock Text="·" Foreground="{DynamicResource SecondaryText}" FontSize="11" Opacity="0.5"
                                               IsVisible="{Binding LastReadTime, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    <TextBlock Text="{Binding LastReadTime}" Foreground="{DynamicResource SecondaryText}" 
                                               FontSize="11" Opacity="0.6" MaxLines="1"
                                               IsVisible="{Binding LastReadTime, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                </StackPanel>
                            </StackPanel>
                         </Button>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Virtualized List ListBox -->
            <ListBox x:Name="LibraryListModeBox" Grid.Row="1" ItemsSource="{Binding LibraryItems}" 
                     Background="Transparent" BorderThickness="0" 
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     IsVisible="{Binding ShowListView}">
                <ListBox.Styles>
                    <!-- Disable default ListBoxItem selection styles -->
                    <Style Selector="ListBoxItem">
                         <Setter Property="Padding" Value="0"/>
                         <Setter Property="Margin" Value="0"/>
                         <Setter Property="Background" Value="Transparent"/>
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </ListBox.Styles>

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Vertical" Margin="30,0,30,0"/> 
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:MangaItem">
                         <Button x:CompileBindings="False" Background="Transparent" Padding="0" Margin="0,0,0,4"
                                 Command="{Binding DataContext.OpenMangaCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}}"
                                 CommandParameter="{Binding}"
                                 HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                             <Button.Styles>
                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="{DynamicResource SidebarBackground}"/>
                                </Style>
                             </Button.Styles>
                             
                             <Border CornerRadius="8" Padding="8" Background="Transparent"
                                     PointerPressed="OnMangaCardPointerPressed"
                                     PointerMoved="OnMangaCardPointerMoved"
                                     PointerReleased="OnMangaCardPointerReleased">
                                 <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Mark as Read"
                                                  x:CompileBindings="False"
                                                  Command="{Binding #root.DataContext.MarkAsReadCommand}"
                                                  CommandParameter="{Binding}"/>
                                        <MenuItem Header="Mark as Unread"
                                                  x:CompileBindings="False"
                                                  Command="{Binding #root.DataContext.MarkAsUnreadCommand}"
                                                  CommandParameter="{Binding}"/>
                                        <MenuItem Header="Edit Categories..."
                                                  x:CompileBindings="False"
                                                  Command="{Binding #root.DataContext.EditMangaCategoriesCommand}"
                                                  CommandParameter="{Binding}"/>
                                        <Separator/>
                                        <MenuItem Header="Remove from Library (Keep Files)"
                                                  x:CompileBindings="False"
                                                  Command="{Binding #root.DataContext.RemoveMangaCommand}"
                                                  CommandParameter="{Binding}"/>
                                         <MenuItem Header="Delete All Downloads" Foreground="#FF5555"
                                                   x:CompileBindings="False"
                                                   Command="{Binding #root.DataContext.DeleteMangaDownloadsCommand}"
                                                   CommandParameter="{Binding}"/>
                                         <MenuItem Header="Delete from Disk" Foreground="#FF5555"
                                                   x:CompileBindings="False"
                                                   Command="{Binding #root.DataContext.DeleteMangaCommand}"
                                                   CommandParameter="{Binding}"/>
                                    </ContextMenu>
                                </Border.ContextMenu>

                                <Grid ColumnDefinitions="40, 16, *, Auto">
                                    <!-- Tiny Cover Image -->
                                    <Border Grid.Column="0" Height="55" Width="40" CornerRadius="4" ClipToBounds="True" Background="{DynamicResource SidebarBackground}">
                                        <Image helpers:SecureImageLoader.Url="{Binding CoverUrl}" Stretch="UniformToFill"/>
                                    </Border>
                                    
                                    <!-- Text Info -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="4">
                                        <TextBlock Text="{Binding Title}" Foreground="{DynamicResource PrimaryText}" 
                                                   TextAlignment="Left" TextTrimming="CharacterEllipsis"
                                                   FontSize="14" FontWeight="SemiBold" MaxLines="1"/>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding SourceName}" Foreground="{DynamicResource SecondaryText}" 
                                                       FontSize="12" Opacity="0.7" MaxLines="1" TextTrimming="CharacterEllipsis"
                                                       IsVisible="{Binding SourceName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            <TextBlock Text="·" Foreground="{DynamicResource SecondaryText}" FontSize="12" Opacity="0.5"
                                                       IsVisible="{Binding LastReadTime, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            <TextBlock Text="{Binding LastReadTime}" Foreground="{DynamicResource SecondaryText}" 
                                                       FontSize="12" Opacity="0.6" MaxLines="1"
                                                       IsVisible="{Binding LastReadTime, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Badges -->
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <!-- NEW Badge -->
                                        <Border Background="#89B4FA" CornerRadius="4" Padding="6,2"
                                                IsVisible="{Binding IsNewBadgeVisible}">
                                            <TextBlock Text="NEW" Foreground="#1E1E2E" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                        <!-- Unread Badge -->
                                        <Border Background="#0078D7" CornerRadius="4" Padding="6,2" MinWidth="24"
                                                IsVisible="{Binding UnreadCount, Converter={x:Static ObjectConverters.IsNotNull}}">
                                            <TextBlock Text="{Binding UnreadCount}" Foreground="#FFFFFF" 
                                                       FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        </Border>
                                        <!-- Download Badge -->
                                        <Border Background="#059669" CornerRadius="4" Padding="6,2"
                                                IsVisible="{Binding IsDownloadedBadgeVisible}">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="&#xE896;" FontFamily="Segoe Fluent Icons" Foreground="#FFFFFF" 
                                                           FontSize="9" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding DownloadedCount}" Foreground="#FFFFFF" 
                                                           FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                             </Border>
                         </Button>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Sync Overlay (Skeleton Grid Loading View) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Disabled" IsVisible="{Binding IsRefreshing}" Margin="30,0,30,0">
                <WrapPanel Orientation="Horizontal" ItemWidth="175" ItemHeight="310" HorizontalAlignment="Center">
                    <!-- 14 Skeleton cards to fill the screen -->
                    <StackPanel Width="150" Margin="10,0,10,20" Spacing="8">
                        <Border Classes="SkeletonCard" Height="225" Width="150"/>
                        <Border Classes="SkeletonText" Width="120" Height="14" HorizontalAlignment="Left"/>
                        <Border Classes="SkeletonText" Width="80" Height="10" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Width="150" Margin="10,0,10,20" Spacing="8">
                        <Border Classes="SkeletonCard" Height="225" Width="150"/>
                        <Border Classes="SkeletonText" Width="110" Height="14" HorizontalAlignment="Left"/>
                        <Border Classes="SkeletonText" Width="70" Height="10" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Width="150" Margin="10,0,10,20" Spacing="8">
                        <Border Classes="SkeletonCard" Height="225" Width="150"/>
                        <Border Classes="SkeletonText" Width="130" Height="14" HorizontalAlignment="Left"/>
                        <Border Classes="SkeletonText" Width="90" Height="10" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Width="150" Margin="10,0,10,20" Spacing="8">
                        <Border Classes="SkeletonCard" Height="225" Width="150"/>
                        <Border Classes="SkeletonText" Width="100" Height="14" HorizontalAlignment="Left"/>
                        <Border Classes="SkeletonText" Width="60" Height="10" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Width="150" Margin="10,0,10,20" Spacing="8">
                        <Border Classes="SkeletonCard" Height="225" Width="150"/>
                        <Border Classes="SkeletonText" Width="125" Height="14" HorizontalAlignment="Left"/>
                        <Border Classes="SkeletonText" Width="85" Height="10" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Width="150" Margin="10,0,10,20" Spacing="8">
                        <Border Classes="SkeletonCard" Height="225" Width="150"/>
                        <Border Classes="SkeletonText" Width="115" Height="14" HorizontalAlignment="Left"/>
                        <Border Classes="SkeletonText" Width="75" Height="10" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Width="150" Margin="10,0,10,20" Spacing="8">
                        <Border Classes="SkeletonCard" Height="225" Width="150"/>
                        <Border Classes="SkeletonText" Width="105" Height="14" HorizontalAlignment="Left"/>
                        <Border Classes="SkeletonText" Width="65" Height="10" HorizontalAlignment="Left"/>
                    </StackPanel>
                    
                    <StackPanel Width="150" Margin="10,0,10,20" Spacing="8">
                        <Border Classes="SkeletonCard" Height="225" Width="150"/>
                        <Border Classes="SkeletonText" Width="110" Height="14" HorizontalAlignment="Left"/>
                        <Border Classes="SkeletonText" Width="80" Height="10" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Width="150" Margin="10,0,10,20" Spacing="8">
                        <Border Classes="SkeletonCard" Height="225" Width="150"/>
                        <Border Classes="SkeletonText" Width="120" Height="14" HorizontalAlignment="Left"/>
                        <Border Classes="SkeletonText" Width="70" Height="10" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Width="150" Margin="10,0,10,20" Spacing="8">
                        <Border Classes="SkeletonCard" Height="225" Width="150"/>
                        <Border Classes="SkeletonText" Width="95" Height="14" HorizontalAlignment="Left"/>
                        <Border Classes="SkeletonText" Width="65" Height="10" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Width="150" Margin="10,0,10,20" Spacing="8">
                        <Border Classes="SkeletonCard" Height="225" Width="150"/>
                        <Border Classes="SkeletonText" Width="115" Height="14" HorizontalAlignment="Left"/>
                        <Border Classes="SkeletonText" Width="75" Height="10" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Width="150" Margin="10,0,10,20" Spacing="8">
                        <Border Classes="SkeletonCard" Height="225" Width="150"/>
                        <Border Classes="SkeletonText" Width="105" Height="14" HorizontalAlignment="Left"/>
                        <Border Classes="SkeletonText" Width="60" Height="10" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Width="150" Margin="10,0,10,20" Spacing="8">
                        <Border Classes="SkeletonCard" Height="225" Width="150"/>
                        <Border Classes="SkeletonText" Width="125" Height="14" HorizontalAlignment="Left"/>
                        <Border Classes="SkeletonText" Width="85" Height="10" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Width="150" Margin="10,0,10,20" Spacing="8">
                        <Border Classes="SkeletonCard" Height="225" Width="150"/>
                        <Border Classes="SkeletonText" Width="110" Height="14" HorizontalAlignment="Left"/>
                        <Border Classes="SkeletonText" Width="70" Height="10" HorizontalAlignment="Left"/>
                    </StackPanel>
                </WrapPanel>
            </ScrollViewer>
        </Grid>

        <!-- Skeleton Loading State -->
        <WrapPanel Orientation="Horizontal" Margin="30,120,30,30" IsVisible="{Binding IsLoading}">
            <StackPanel Width="150" Margin="10,0,10,20" Spacing="8">
                <Border Classes="SkeletonCard" Height="225" Width="150"/>
                <Border Classes="SkeletonText" Width="120" Height="14"/>
                <Border Classes="SkeletonText" Width="80" Height="10"/>
            </StackPanel>
            <StackPanel Width="150" Margin="10,0,10,20" Spacing="8">
                <Border Classes="SkeletonCard" Height="225" Width="150"/>
                <Border Classes="SkeletonText" Width="110" Height="14"/>
                <Border Classes="SkeletonText" Width="70" Height="10"/>
            </StackPanel>
            <StackPanel Width="150" Margin="10,0,10,20" Spacing="8">
                <Border Classes="SkeletonCard" Height="225" Width="150"/>
                <Border Classes="SkeletonText" Width="130" Height="14"/>
                <Border Classes="SkeletonText" Width="90" Height="10"/>
            </StackPanel>
            <StackPanel Width="150" Margin="10,0,10,20" Spacing="8">
                <Border Classes="SkeletonCard" Height="225" Width="150"/>
                <Border Classes="SkeletonText" Width="100" Height="14"/>
                <Border Classes="SkeletonText" Width="60" Height="10"/>
            </StackPanel>
            <StackPanel Width="150" Margin="10,0,10,20" Spacing="8">
                <Border Classes="SkeletonCard" Height="225" Width="150"/>
                <Border Classes="SkeletonText" Width="125" Height="14"/>
                <Border Classes="SkeletonText" Width="85" Height="10"/>
            </StackPanel>
            <StackPanel Width="150" Margin="10,0,10,20" Spacing="8">
                <Border Classes="SkeletonCard" Height="225" Width="150"/>
                <Border Classes="SkeletonText" Width="115" Height="14"/>
                <Border Classes="SkeletonText" Width="75" Height="10"/>
            </StackPanel>
        </WrapPanel>

        <!-- Empty State (Only if NOT loading and IS empty) -->
        <!-- Case 1: Library Empty (No Items) -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
             <StackPanel.IsVisible>
                <MultiBinding Converter="{x:Static BoolConverters.And}">
                    <Binding Path="IsLibraryEmpty"/>
                    <Binding Path="!IsLoading"/>
                </MultiBinding>
             </StackPanel.IsVisible>

            <TextBlock Text="&#xE7BC;" FontFamily="Segoe Fluent Icons" FontSize="48" Foreground="{DynamicResource HoverBackground}" HorizontalAlignment="Center"/>
            <TextBlock Text="Your library is empty." FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center"/>
            <TextBlock Text="Add manga from Browse section to start reading." FontSize="16" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center"/>
            
            <Button Content="Browse Sources" Classes="NavBtn" Background="#0078D7" Foreground="#FFFFFF" Padding="20,10" CornerRadius="8"
                    Command="{Binding GoToBrowseCommand}" 
                    HorizontalAlignment="Center" Margin="0,10,0,0"/>
        </StackPanel>

        <!-- Case 2: No Search Results -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
             <StackPanel.IsVisible>
                <MultiBinding Converter="{x:Static BoolConverters.And}">
                    <Binding Path="HasNoResults"/>
                    <Binding Path="!IsLoading"/>
                </MultiBinding>
             </StackPanel.IsVisible>

            <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons" FontSize="48" Foreground="#45475A" HorizontalAlignment="Center"/>
            <TextBlock Text="No results found" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center"/>
            <TextBlock Text="Try searching for something else." FontSize="16" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Filter Overlay REMOVED for debugging -->

    </Panel>
</UserControl>
