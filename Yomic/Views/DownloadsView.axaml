<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Yomic.ViewModels"
             xmlns:helpers="clr-namespace:Yomic.Views.Helpers"
             x:Class="Yomic.Views.DownloadsView"
             x:DataType="vm:DownloadsViewModel"
             Background="{DynamicResource PrimaryBackground}">
    
    <UserControl.Styles>
        <Style Selector="Button.header-action">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
        </Style>
        <Style Selector="Button.header-action:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        </Style>

        <!-- Disable transitions for header buttons to avoid color "lag" -->
        <Style Selector="Button.header-action TextBlock">
             <Setter Property="Transitions" Value="{x:Null}"/>
        </Style>
        
        <Style Selector="Button.hazard">
            <Setter Property="Foreground" Value="#F38BA8"/>
        </Style>
        <Style Selector="Button.hazard:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#20F38BA8"/>
        </Style>
        <Style Selector="Button.header-action.hazard:pointerover">
            <Setter Property="Foreground" Value="#F38BA8"/>
        </Style>
        
        <Style Selector="Button.success">
            <Setter Property="Foreground" Value="#A6E3A1"/>
        </Style>
        <Style Selector="Button.success:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#20A6E3A1"/>
        </Style>
        <Style Selector="Button.header-action.success:pointerover">
            <Setter Property="Foreground" Value="#A6E3A1"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *">
        <!-- Header Actions -->
        <StackPanel Grid.Row="0" Margin="30,25,30,15" IsVisible="{Binding HasDownloads}">
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="&#xE896;" FontFamily="Segoe Fluent Icons" FontSize="24" 
                               Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"
                               RenderOptions.TextRenderingMode="Antialias"/>
                    <TextBlock Text="Downloads" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                    
                    <Border Background="{DynamicResource ControlBackground}" CornerRadius="10" Padding="10,3" IsVisible="{Binding HasQueue}" VerticalAlignment="Center">
                        <TextBlock Text="{Binding QueueCount, StringFormat='{}{0} In Queue'}" 
                                   Foreground="{DynamicResource SecondaryText}" FontSize="11" VerticalAlignment="Center" FontWeight="Medium"/>
                    </Border>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button Command="{Binding ResumeAllCommand}" Classes="header-action success" ToolTip.Tip="Resume All"
                            IsVisible="{Binding HasQueue}">
                         <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Resume All" VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding PauseAllCommand}" Classes="header-action" ToolTip.Tip="Pause All"
                            IsVisible="{Binding HasQueue}">
                         <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#xE769;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Pause All" VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ClearCompletedCommand}" Classes="header-action hazard" ToolTip.Tip="Clear Completed">
                         <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Clear Completed" VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
            <TextBlock Text="Manage your ongoing and queued downloads" Foreground="{DynamicResource SecondaryText}" Margin="0,4,0,0" FontSize="13" Opacity="0.8"/>
        </StackPanel>

        <!-- List Content (ListBox for Virtualization + Built-in Scroll) -->
        <ListBox Grid.Row="1" ItemsSource="{Binding QueuedItems}" 
                 Background="Transparent" BorderThickness="0"
                 Padding="30"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 IsVisible="{Binding HasDownloads}">
            
            <ListBox.Styles>
                <!-- Disable Selection Highlight -->
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
                <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
                <Style Selector="ListBoxItem:selected:focus /template/ ContentPresenter">
                    <Setter Property="Background" Value="Transparent"/>
                </Style>

                <Style Selector="Border.download-item">
                    <Setter Property="Background" Value="{DynamicResource SidebarBackground}"/>
                    <Setter Property="Transitions">
                        <Transitions>
                            <BrushTransition Property="Background" Duration="0:0:0.15"/>
                        </Transitions>
                    </Setter>
                </Style>
                <Style Selector="Border.download-item:pointerover">
                    <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                </Style>
            </ListBox.Styles>

            <ListBox.ItemTemplate>
                <DataTemplate>
                     <Border Classes="download-item" CornerRadius="12" Padding="15" Margin="0,0,0,10"
                             BoxShadow="0 2 6 0 #15000000">
                        <Border.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Save as CBZ" Command="{Binding ExportCommand}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE74E;" FontFamily="Segoe Fluent Icons"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Border.ContextMenu>
                        <Grid ColumnDefinitions="*, Auto">
                            <Button Grid.Column="0" Command="{Binding OpenChapterCommand}" Background="Transparent" BorderThickness="0" Padding="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Cursor="Hand">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                    <Style Selector="Button:pressed /template/ ContentPresenter">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                    <Style Selector="Button:pressed TextBlock">
                                        <Setter Property="Opacity" Value="0.7"/>
                                    </Style>
                                </Button.Styles>
                                <Grid ColumnDefinitions="Auto, *">
                                    <Border Grid.Column="0" Width="45" Height="65" Background="{DynamicResource OverlayBackground}" CornerRadius="8" ClipToBounds="True">
                                         <Panel>
                                              <TextBlock Text="IMG" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                                              <Image helpers:SecureImageLoader.Url="{Binding Request.Manga.ThumbnailUrl}" Stretch="UniformToFill"/>
                                         </Panel>
                                    </Border>
                                    
                                    <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" Foreground="{DynamicResource PrimaryText}" FontWeight="SemiBold" FontSize="13" MaxLines="1" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding ChapterName}" Foreground="{DynamicResource SecondaryText}" FontSize="12" Margin="0,2,0,8" MaxLines="1" TextTrimming="CharacterEllipsis"/>
                                        
                                        <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding ShowProgress}" VerticalAlignment="Center">
                                             <ProgressBar Value="{Binding Progress}" Maximum="100" Height="4" Width="200"
                                                     Background="{DynamicResource ControlBackground}" Foreground="{Binding StatusColor}" CornerRadius="2"
                                                     IsIndeterminate="{Binding IsIndeterminate}"
                                                     VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Progress, StringFormat='{}{0}%'}" Foreground="{Binding StatusColor}" FontSize="11" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        
                                        <TextBlock Text="{Binding Status}" Foreground="{Binding StatusColor}" FontSize="11" FontWeight="Medium" IsVisible="{Binding !ShowProgress}"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button Grid.Column="1" Command="{Binding CancelCommand}" 
                                    Classes="header-action" Foreground="{DynamicResource SecondaryText}"
                                    ToolTip.Tip="Cancel Download" Padding="8" CornerRadius="20" VerticalAlignment="Center" Margin="10,0,0,0">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover">
                                        <Setter Property="Foreground" Value="#F38BA8"/>
                                    </Style>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="#15F38BA8"/>
                                    </Style>
                                </Button.Styles>
                                <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="16"/>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- EMPTY STATE -->
        <!-- EMPTY STATE -->
        <StackPanel Grid.Row="0" Grid.RowSpan="2" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20"
                    IsVisible="{Binding !HasDownloads}">
            <TextBlock Text="&#xE896;" FontFamily="Segoe Fluent Icons" FontSize="64" Foreground="#45475A" HorizontalAlignment="Center"/>
            <StackPanel Spacing="8">
                <TextBlock Text="No Downloads Yet" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center"/>
                <TextBlock Text="Downloaded chapters will appear here." FontSize="14" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" Opacity="0.8"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
