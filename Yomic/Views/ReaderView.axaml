<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Yomic.ViewModels"
             x:Class="Yomic.Views.ReaderView"
             x:DataType="vm:ReaderViewModel"
             Background="{DynamicResource PrimaryBackground}"
             Focusable="True">
    
    <UserControl.Styles>
        <Style Selector="Button.NavBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="CornerRadius" Value="50"/>
            <Setter Property="Focusable" Value="False"/>
        </Style>

        <Style Selector="TextBlock.Active">
             <Setter Property="Foreground" Value="#0078D7"/>
        </Style>
        
        <!-- Image Animation Styles -->
        <Style Selector="Image.PageImage">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Image.PageImage.Loaded">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Button.ActionBtn">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.ActionBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
        </Style>
        <Style Selector="Button.ActionBtn:pointerover">
             <Setter Property="RenderTransform" Value="scale(1.05)"/>
        </Style>
        
        <!-- Custom Flyout Style -->
        <Style Selector="FlyoutPresenter.TransparentFlyout">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <!-- BoxShadow is not a direct property of FlyoutPresenter in this context, removing it to fix build -->
        </Style>

        <!-- Modern ScrollBar Style -->
        <Style Selector="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="10"/>
        </Style>
        <Style Selector="ScrollBar:vertical">
            <Setter Property="Width" Value="10"/>
        </Style>
        <Style Selector="ScrollBar /template/ Thumb">
            <Setter Property="Background" Value="#40FFFFFF"/>
            <Setter Property="CornerRadius" Value="5"/>
        </Style>
        <Style Selector="ScrollBar /template/ Thumb:pointerover">
            <Setter Property="Background" Value="#80FFFFFF"/>
        </Style>

        <!-- Custom iOS/Mac-style Thick Slider -->
        <Style Selector="Slider.IosSlider">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Height="24"
                            ClipToBounds="True">
                        <Grid>
                            <!-- Track (Intercepts Clicks) -->
                            <Track Name="PART_Track" 
                                   Minimum="{TemplateBinding Minimum}" 
                                   Maximum="{TemplateBinding Maximum}" 
                                   Value="{TemplateBinding Value, Mode=TwoWay}"
                                   IsDirectionReversed="{TemplateBinding IsDirectionReversed}"
                                   Orientation="Horizontal">
                                   
                                <Track.DecreaseButton>
                                    <RepeatButton Name="PART_DecreaseButton" Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Slider}}" Focusable="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <RepeatButton.Template>
                                            <ControlTemplate>
                                                <!-- Flat edges rely on parent Border's ClipToBounds for perfect capping at 0% and 100% -->
                                                <Border Background="{TemplateBinding Background}" CornerRadius="0" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseButton>

                                <Track.IncreaseButton>
                                    <RepeatButton Name="PART_IncreaseButton" Background="Transparent" Focusable="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <RepeatButton.Template>
                                            <ControlTemplate>
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseButton>

                                <!-- Zero-width logical thumb allowing the fill bar to naturally span 0-100% smoothly without layout offsets -->
                                <Thumb Name="PART_SliderThumb" Width="0" Height="24" Cursor="Hand">
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <!-- Transparent drag hit-box that extends 12px out in both directions so it remains easy to grab -->
                                            <Border Background="Transparent" 
                                                    Width="24" Height="24"
                                                    Margin="-12,0,-12,0" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Slider.IosSlider[Orientation=Vertical]">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="MinWidth" Value="24"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Width="24"
                            ClipToBounds="True">
                        <Grid>
                            <Track Name="PART_Track" 
                                   Minimum="{TemplateBinding Minimum}" 
                                   Maximum="{TemplateBinding Maximum}" 
                                   Value="{TemplateBinding Value, Mode=TwoWay}"
                                   IsDirectionReversed="False"
                                   Orientation="Vertical">
                                   
                                <Track.DecreaseButton>
                                    <RepeatButton Name="PART_DecreaseButton" Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Slider}}" Focusable="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <RepeatButton.Template>
                                            <ControlTemplate>
                                                <!-- Fills from bottom-up naturally -->
                                                <Border Background="{TemplateBinding Background}" CornerRadius="12" Margin="0,-24,0,0" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseButton>

                                <Track.IncreaseButton>
                                    <RepeatButton Name="PART_IncreaseButton" Background="Transparent" Focusable="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <RepeatButton.Template>
                                            <ControlTemplate>
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseButton>

                                <Thumb Name="PART_SliderThumb" Width="24" Height="0" Cursor="Hand">
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <!-- Transparent drag hit-box that extends 12px out vertically -->
                                            <Border Background="Transparent" 
                                                    Width="24" Height="24"
                                                    Margin="0,-12,0,-12" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>        
    </UserControl.Styles>

    <Panel Background="Transparent">
        <!-- Layer 0: Image Render -->
        <Panel>
            <!-- Webtoon Mode -->
            <!-- Virtualizing ListBox for Webtoon Mode -->
            <ListBox x:Name="MainListBox"
                     IsVisible="{Binding IsWebtoon}"
                     ItemsSource="{Binding Pages}" 
                     HorizontalAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.ScrollChanged="OnScrollChanged"
                     SelectionMode="Single">
                     <ListBox.Styles>
                         <!-- Remove ListBoxItem default padding/margin/hover -->
                         <Style Selector="ListBoxItem">
                             <Setter Property="Padding" Value="0"/>
                             <Setter Property="Margin" Value="0"/>
                             <Setter Property="Template">
                                 <ControlTemplate>
                                     <ContentPresenter Name="PART_ContentPresenter"
                                                       Background="{TemplateBinding Background}"
                                                       BorderBrush="{TemplateBinding BorderBrush}"
                                                       BorderThickness="{TemplateBinding BorderThickness}"
                                                       ContentTemplate="{TemplateBinding ContentTemplate}"
                                                       Content="{TemplateBinding Content}"
                                                       Padding="{TemplateBinding Padding}"
                                                       VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                                       HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}" />
                                 </ControlTemplate>
                             </Setter>
                         </Style>
                         <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                             <Setter Property="Background" Value="Transparent"/>
                         </Style>
                         <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                             <Setter Property="Background" Value="Transparent"/>
                         </Style>
                     </ListBox.Styles>
                     
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                     <ListBox.ItemTemplate>
                         <DataTemplate x:DataType="vm:PageViewModel">
                             <!-- Removing AttachedToVisualTree to prevent all items loading instantly. ReaderViewModel.PreloadAroundIndex will handle lazy loading via scroll position. -->
                             <Panel Margin="0"
                                    x:CompileBindings="False"
                                    MaxWidth="{Binding DataContext.WebtoonWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    HorizontalAlignment="Center">
                                 <Grid MinHeight="150">
                                     <!-- Loading Indicator -->
                                     <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" IsVisible="{Binding IsLoading}">
                                         <TextBlock Text="Loading..." Foreground="#555" HorizontalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
                                     </StackPanel>

                                     <!-- Image (Always participates in layout bounds to prevent VirtualizingStackPanel overlap bugs) -->
                                     <Image Classes="PageImage"
                                            Classes.Loaded="{Binding !IsLoading}"
                                            Source="{Binding Image}" 
                                            Stretch="Uniform" 
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Top"
                                            RenderOptions.BitmapInterpolationMode="HighQuality">
                                         <Image.Effect>
                                             <BlurEffect Radius="{Binding BlurRadius}"/>
                                         </Image.Effect>
                                     </Image>
                                 </Grid>
                             </Panel>
                         </DataTemplate>
                     </ListBox.ItemTemplate>
                 </ListBox>

            <!-- Paged Mode -->
            <Grid IsVisible="{Binding IsPaged}" Background="Black">
                <ScrollViewer x:Name="PagedScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <LayoutTransformControl HorizontalAlignment="Center" VerticalAlignment="Center">
                        <LayoutTransformControl.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding ZoomScale}" ScaleY="{Binding ZoomScale}"/>
                        </LayoutTransformControl.LayoutTransform>

                        <ContentControl Content="{Binding CurrentPage}"
                                        MaxHeight="{Binding Bounds.Height, ElementName=PagedScroll, Converter={x:Static vm:MathConverters.FitScale}}"
                                        MaxWidth="{Binding Bounds.Width, ElementName=PagedScroll, Converter={x:Static vm:MathConverters.FitScale}}">
                            <ContentControl.ContentTemplate>
                                <DataTemplate x:DataType="vm:PageViewModel">
                                     <Panel>
                                         <TextBlock Text="Loading..." Foreground="#666" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                    IsVisible="{Binding IsLoading}"/>

                                         <Grid>
                                             <Image Source="{Binding Image}" Stretch="Uniform" Margin="10"
                                                    IsVisible="{Binding !IsLoading}">
                                                 <Image.Effect>
                                                     <BlurEffect Radius="{Binding BlurRadius}"/>
                                                 </Image.Effect>
                                             </Image>
                                         </Grid>
                                     </Panel>
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                        </ContentControl>
                    </LayoutTransformControl>
                </ScrollViewer>
            </Grid>

            <!-- Dual Paged Mode (Manga Right-to-Left) -->
            <Grid IsVisible="{Binding IsDualPage}" Background="Black">
                <ScrollViewer x:Name="DualPagedScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <LayoutTransformControl HorizontalAlignment="Center" VerticalAlignment="Center">
                        <LayoutTransformControl.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding ZoomScale}" ScaleY="{Binding ZoomScale}"/>
                        </LayoutTransformControl.LayoutTransform>

                        <Grid ColumnDefinitions="*,*" HorizontalAlignment="Center" VerticalAlignment="Center"
                              MaxHeight="{Binding Bounds.Height, ElementName=DualPagedScroll, Converter={x:Static vm:MathConverters.FitScale}}"
                              MaxWidth="{Binding Bounds.Width, ElementName=DualPagedScroll, Converter={x:Static vm:MathConverters.FitScale}}">
                            <!-- Left Side: Next Page (Index + 1) -->
                            <ContentControl Content="{Binding CurrentPageLeft}" Grid.Column="0">
                                <ContentControl.ContentTemplate>
                                    <DataTemplate x:DataType="vm:PageViewModel">
                                         <Panel>
                                             <TextBlock Text="Loading..." Foreground="#666" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        IsVisible="{Binding IsLoading}"/>
                                             <Grid>
                                                 <Image Source="{Binding Image}" Stretch="Uniform" Margin="10"
                                                        IsVisible="{Binding !IsLoading}">
                                                     <Image.Effect>
                                                         <BlurEffect Radius="{Binding BlurRadius}"/>
                                                     </Image.Effect>
                                                 </Image>
                                             </Grid>
                                         </Panel>
                                    </DataTemplate>
                                </ContentControl.ContentTemplate>
                            </ContentControl>
                            <!-- Right Side: Current Page (Index) -->
                            <ContentControl Content="{Binding CurrentPageRight}" Grid.Column="1">
                                <ContentControl.ContentTemplate>
                                    <DataTemplate x:DataType="vm:PageViewModel">
                                         <Panel>
                                             <TextBlock Text="Loading..." Foreground="#666" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        IsVisible="{Binding IsLoading}"/>
                                             <Grid>
                                                 <Image Source="{Binding Image}" Stretch="Uniform" Margin="10"
                                                        IsVisible="{Binding !IsLoading}">
                                                     <Image.Effect>
                                                         <BlurEffect Radius="{Binding BlurRadius}"/>
                                                     </Image.Effect>
                                                 </Image>
                                             </Grid>
                                         </Panel>
                                    </DataTemplate>
                                </ContentControl.ContentTemplate>
                            </ContentControl>
                        </Grid>
                    </LayoutTransformControl>
                </ScrollViewer>
            </Grid>
            
            <!-- AutoScroll Anchor (Hidden by Default) -->
            <Canvas Name="AutoScrollCanvas" IsVisible="False" IsHitTestVisible="False" ZIndex="100">
                 <Border Name="AutoScrollAnchor" Width="40" Height="40" CornerRadius="20" 
                         Background="#80000000" BorderBrush="White" BorderThickness="2"
                         BoxShadow="0 4 15 0 #40000000"
                         Margin="-20,-20,0,0"> <!-- Centered via negative margin -->
                     <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="-2">
                         <TextBlock Text="&#xE70E;" FontFamily="Segoe Fluent Icons" Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                         <TextBlock Text="&#xE70D;" FontFamily="Segoe Fluent Icons" Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                     </StackPanel>
                 </Border>
            </Canvas>
        </Panel>



        <!-- Layer 2: HUD (Head Up Display) -->
        <Grid RowDefinitions="Auto, *, Auto">
            
            <!-- Top Menu (Header) - Restored & Styled -->
            <Border Grid.Row="0" Background="{DynamicResource SidebarBackground}" Opacity="0.95"
                    IsVisible="{Binding IsHeaderVisible}"
                    HorizontalAlignment="Stretch" VerticalAlignment="Top"
                    Padding="20,10" BorderThickness="0">

                <Grid ColumnDefinitions="Auto, *, Auto">
                    <!-- Back Button (Left) -->
                    <Button Grid.Column="0" Classes="NavBtn" 
                            Command="{Binding BackCommand}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" FontSize="18"/>
                    </Button>

                    <!-- Title Info (Center) -->
                    <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0">
                         <TextBlock Text="{Binding Title}" Foreground="{DynamicResource PrimaryText}" FontWeight="Bold" HorizontalAlignment="Center" FontSize="16"
                                    TextTrimming="CharacterEllipsis" MaxLines="1"/>
                         <TextBlock Text="{Binding ChapterTitle}" Foreground="{DynamicResource SecondaryText}" FontSize="12" HorizontalAlignment="Center"
                                    TextTrimming="CharacterEllipsis" MaxLines="1"/>
                    </StackPanel>

                    <!-- Right Controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Refresh Button -->
                        <Button Classes="NavBtn" 
                                Command="{Binding RefreshCommand}"
                                ToolTip.Tip="Refresh">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons" FontSize="18"/>
                        </Button>
                        
                        <!-- Fullscreen Button -->
                        <Button Classes="NavBtn" 
                                Command="{Binding ToggleFullscreenCommand}"
                                ToolTip.Tip="Toggle Fullscreen">
                            <Panel>
                                <TextBlock Text="&#xE740;" FontFamily="Segoe Fluent Icons" FontSize="18"
                                           IsVisible="{Binding !IsFullscreen}"/>
                                <TextBlock Text="&#xE73F;" FontFamily="Segoe Fluent Icons" FontSize="18"
                                           IsVisible="{Binding IsFullscreen}"/>
                            </Panel>
                        </Button>
                        
                        <!-- Reading Mode -->
                        <Button Classes="NavBtn" ToolTip.Tip="Reading Mode">
                            <Button.Flyout>
                                <Flyout Placement="BottomEdgeAlignedRight" ShowMode="Standard" FlyoutPresenterClasses="TransparentFlyout">
                                    <Border Background="{DynamicResource SidebarBackground}" CornerRadius="12" Padding="8" BorderBrush="{DynamicResource HoverBackground}" BorderThickness="1" MinWidth="160" BoxShadow="0 8 24 0 #30000000">
                                        <StackPanel Orientation="Vertical" Spacing="4">
                                            <Button Background="Transparent" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12,10" CornerRadius="8"
                                                    Command="{Binding SetModeCommand}" CommandParameter="{x:Static vm:ReaderMode.Webtoon}">
                                                <Grid ColumnDefinitions="Auto, *, Auto">
                                                    <TextBlock Grid.Column="0" Text="&#xE81E;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock Grid.Column="1" Text="Webtoon" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="&#xE73E;" FontFamily="Segoe Fluent Icons" FontSize="12" VerticalAlignment="Center" Foreground="{DynamicResource AccentColor}" IsVisible="{Binding IsWebtoon}"/>
                                                </Grid>
                                            </Button>
                                            <Button Background="Transparent" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12,10" CornerRadius="8"
                                                    Command="{Binding SetModeCommand}" CommandParameter="{x:Static vm:ReaderMode.Single}">
                                                <Grid ColumnDefinitions="Auto, *, Auto">
                                                    <TextBlock Grid.Column="0" Text="&#xE7C3;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock Grid.Column="1" Text="Single Page" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="&#xE73E;" FontFamily="Segoe Fluent Icons" FontSize="12" VerticalAlignment="Center" Foreground="{DynamicResource AccentColor}" IsVisible="{Binding IsPaged}"/>
                                                </Grid>
                                            </Button>
                                            <Button Background="Transparent" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12,10" CornerRadius="8"
                                                    Command="{Binding SetModeCommand}" CommandParameter="{x:Static vm:ReaderMode.Double}">
                                                <Grid ColumnDefinitions="Auto, *, Auto">
                                                    <TextBlock Grid.Column="0" Text="&#xE8A5;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock Grid.Column="1" Text="Dual Page" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="&#xE73E;" FontFamily="Segoe Fluent Icons" FontSize="12" VerticalAlignment="Center" Foreground="{DynamicResource AccentColor}" IsVisible="{Binding IsDualPage}"/>
                                                </Grid>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Flyout>
                            </Button.Flyout>
                            <TextBlock Text="&#xE8F1;" FontFamily="Segoe Fluent Icons" FontSize="18"/>
                        </Button>

                        <!-- Zoom Controls -->
                        <Button Classes="NavBtn" ToolTip.Tip="Zoom Options">
                            <Button.Flyout>
                                <Flyout Placement="BottomEdgeAlignedRight" ShowMode="Standard" FlyoutPresenterClasses="TransparentFlyout">
                                    <Border Background="{DynamicResource SidebarBackground}" CornerRadius="16" Padding="15,20" BorderBrush="{DynamicResource HoverBackground}" BorderThickness="1" MinWidth="100" BoxShadow="0 8 24 0 #30000000">
                                        <StackPanel Orientation="Vertical" Spacing="10" HorizontalAlignment="Center">
                                            <!-- Value Label -->
                                            <TextBlock Text="{Binding ZoomScale, StringFormat='{}{0:P0}'}" Foreground="{DynamicResource AccentColor}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
                                            
                                            <!-- Slider -->
                                            <Slider Classes="IosSlider"
                                                    Orientation="Vertical"
                                                    Foreground="{DynamicResource AccentColor}"
                                                    Background="{DynamicResource HoverBackground}"
                                                    Value="{Binding ZoomScale}" 
                                                    Minimum="0.1" Maximum="2.0" 
                                                    Height="140"
                                                    IsSnapToTickEnabled="True" 
                                                    TickFrequency="0.1"/>
                                        </StackPanel>
                                    </Border>
                                </Flyout>
                            </Button.Flyout>
                            <TextBlock Text="&#xE71E;" FontFamily="Segoe Fluent Icons" FontSize="18"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Bottom Menu (Fixed Bottom Bar) -->
            <Border Grid.Row="2" Background="{DynamicResource SidebarBackground}" Opacity="0.95"
                    IsVisible="{Binding IsFooterVisible}"
                    HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                    Padding="30,15">

                <StackPanel Spacing="10" MaxWidth="1200" HorizontalAlignment="Stretch">
                    
                    <!-- Page Indicator Pill -->
                    <Border Background="{DynamicResource HoverBackground}" CornerRadius="15" Padding="15,6" 
                            HorizontalAlignment="Center" Margin="0,0,0,2"
                            BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Page" Foreground="{DynamicResource SecondaryText}" FontSize="11" VerticalAlignment="Center" Opacity="0.8"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding CurrentPageIndex, Converter={x:Static vm:MathConverters.AddOne}}" 
                                           Foreground="{DynamicResource AccentColor}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="/" Foreground="{DynamicResource SecondaryText}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Pages.Count}" Foreground="{DynamicResource PrimaryText}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Single Row: Prev | Slider | Next -->
                    <Grid ColumnDefinitions="Auto, *, Auto" VerticalAlignment="Center">
                        
                        <!-- Prev (Icon Only) -->
                        <Button Grid.Column="0" Classes="NavBtn" 
                                Command="{Binding PrevChapterCommand}"
                                IsEnabled="{Binding HasPrevChapter}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                Padding="10"
                                CornerRadius="20"
                                ToolTip.Tip="Previous Chapter">
                            <TextBlock Text="&#xE72B;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" FontSize="20"/>
                        </Button>

                        <!-- Slider (Center) -->
                        <Slider Grid.Column="1" 
                                Name="ProgressSlider"
                                Classes="IosSlider"
                                Foreground="{DynamicResource AccentColor}"
                                Background="{DynamicResource HoverBackground}"
                                Focusable="False"
                                Minimum="0" 
                                Maximum="{Binding Pages.Count, Converter={x:Static vm:MathConverters.SubtractOne}}" 
                                Value="{Binding CurrentPageIndex, Mode=TwoWay}"
                                ValueChanged="OnSliderValueChanged"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                Margin="15,0"/>

                        <!-- Next (Icon Only) -->
                        <Button Grid.Column="2" Classes="NavBtn" 
                                Command="{Binding NextChapterCommand}"
                                IsEnabled="{Binding HasNextChapter}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="Transparent" 
                                CornerRadius="20"
                                Padding="10"
                                ToolTip.Tip="Next Chapter"> 
                            <TextBlock Text="&#xE72A;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" FontSize="20"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Border Background="#80000000" IsVisible="False">
            <TextBlock Text="Loading..." Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Panel>
</UserControl>
