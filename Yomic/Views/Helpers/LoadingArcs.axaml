<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="100" d:DesignHeight="100"
             x:Class="Yomic.Views.Helpers.LoadingArcs"
             Width="60" Height="60"
             HorizontalAlignment="Center" VerticalAlignment="Center">
    <UserControl.Styles>
        <Style Selector="Arc.outer">
            <Style.Animations>
                <Animation Duration="0:0:1.6" IterationCount="Infinite">
                    <KeyFrame KeyTime="0:0:0">
                        <Setter Property="RotateTransform.Angle" Value="0"/>
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:1.6">
                        <Setter Property="RotateTransform.Angle" Value="360"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Arc.middle">
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="Infinite">
                    <KeyFrame KeyTime="0:0:0">
                        <Setter Property="RotateTransform.Angle" Value="0"/>
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:1.2">
                        <Setter Property="RotateTransform.Angle" Value="-360"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Arc.inner">
            <Style.Animations>
                <Animation Duration="0:0:0.8" IterationCount="Infinite">
                    <KeyFrame KeyTime="0:0:0">
                        <Setter Property="RotateTransform.Angle" Value="0"/>
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:0.8">
                        <Setter Property="RotateTransform.Angle" Value="360"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>

    <Grid Width="60" Height="60">
        <!-- Outer Arc -->
        <Arc Classes="outer" Width="50" Height="50" 
             Stroke="{DynamicResource PrimaryAccent}" StrokeThickness="3" 
             StartAngle="0" SweepAngle="280" 
             StrokeLineCap="Round" VerticalAlignment="Center" HorizontalAlignment="Center"
             RenderTransformOrigin="50%,50%">
            <Arc.RenderTransform>
                <RotateTransform/>
            </Arc.RenderTransform>
        </Arc>

        <!-- Middle Arc -->
        <Arc Classes="middle" Width="34" Height="34" 
             Stroke="{DynamicResource PrimaryAccent}" Opacity="0.7" StrokeThickness="3" 
             StartAngle="120" SweepAngle="280" 
             StrokeLineCap="Round" VerticalAlignment="Center" HorizontalAlignment="Center"
             RenderTransformOrigin="50%,50%">
            <Arc.RenderTransform>
                <RotateTransform/>
            </Arc.RenderTransform>
        </Arc>

        <!-- Inner Arc -->
        <Arc Classes="inner" Width="18" Height="18" 
             Stroke="{DynamicResource PrimaryAccent}" Opacity="0.4" StrokeThickness="3" 
             StartAngle="240" SweepAngle="280" 
             StrokeLineCap="Round" VerticalAlignment="Center" HorizontalAlignment="Center"
             RenderTransformOrigin="50%,50%">
            <Arc.RenderTransform>
                <RotateTransform/>
            </Arc.RenderTransform>
        </Arc>
    </Grid>
</UserControl>
