<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Yomic.Views.Helpers.SkeletonCard">
    <UserControl.Styles>
        <Style Selector="Border.skeleton">
            <Setter Property="Background" Value="{DynamicResource SidebarBackground}"/>
            <Style.Animations>
                <Animation Duration="0:0:1.5" IterationCount="INFINITE" PlaybackDirection="Alternate" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.3"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1.0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>

    <Border Classes="skeleton" 
            CornerRadius="{Binding $parent[UserControl].CornerRadius}" 
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            ClipToBounds="True"/>
</UserControl>
